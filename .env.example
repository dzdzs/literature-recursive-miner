# Required: one of OPENAI_API_KEY or API_KEY
OPENAI_API_KEY=
# API_KEY=

# LLM endpoint/model
API_BASE_URL=
OPENAI_MODEL=gpt-5.2

# Optional: fallback provider key when Scholar HTML is blocked
SERPAPI_KEY=

# Pipeline limits
MAX_PAPERS=300
MAX_PROCESSED=0
MAX_RELATED_PER_PAPER=100

# Expansion strategy
CITATION_PROVIDER_PRIORITY=scholar_html,serpapi,semantic_scholar
OPENALEX_TITLE_EXACT_THRESHOLD=0.95
DISABLE_OPENALEX=1

# Task and filter settings
TOPIC=deep research
THEME=deep research
KEYWORD=search
FILTER_1="主题为deep research或search相关"
FILTER_2="多轮优先但非硬过滤，非多轮也保留并在multi_turn_signal标注"
FILTER_3="必须是agent相关工作；若论文主要是RAG，只有明确为agentic RAG（服务于agent的规划/工具使用/多步决策/行动闭环）才保留。"
RELEVANCE_INSTRUCTION="优先保留与deep research/search及agent相关的条目。若是RAG，优先保留agentic RAG；普通RAG可在证据不足时标记uncertain_keep后保留。对于GAIA这类Agent benchmark，若是否涉及搜索能力不确定，也先保留并在rationale中注明uncertain_keep。产品公告/博客/报告（如Deep Research功能可用性公告）只要主题相关也保留。multi-turn仅作为标注，不是硬性过滤条件。"

# Seeds
SEED_1=https://arxiv.org/pdf/2506.11763
SEED_2=https://arxiv.org/pdf/2504.03160
SEED_3=https://arxiv.org/pdf/2311.12983

# Work type instruction (Survey included)
WORK_TYPE_INSTRUCTION="Bench：环境的设计以及在其基础上的评测分析；Agent Evo：使用固定环境对agent训练的工作，包括agent workflow，能够提升agent能力的都算，但是太简单太基本的不要；Env Evo：环境和Agent协同进化的工作；Survey：综述/系统性综述/综述性回顾类论文，单独归类为Survey；News/Report：产品公告、博客、功能发布、行业报告等非论文但与主题相关的条目。"
